# Catálogo público oficial. A consulta de metadados não usa segredo.
VITE_NDVI_STAC_URL=https://stac.dataspace.copernicus.eu/v1

# URL do serviço privado que recorta COGs, aplica a máscara SCL e calcula o NDVI.
# Não coloque client secret, refresh token ou credencial Copernicus no Vite.
VITE_NDVI_API_URL=

# Variáveis abaixo pertencem ao backend e nunca devem ser expostas como VITE_*.
CDSE_CLIENT_ID=
CDSE_CLIENT_SECRET=
CDSE_TOKEN_URL=https://identity.dataspace.copernicus.eu/auth/realms/CDSE/protocol/openid-connect/token
NDVI_CACHE_BUCKET=
NDVI_DATABASE_URL=
NDVI_MINIMUM_VALID_COVERAGE_PERCENTAGE=70
